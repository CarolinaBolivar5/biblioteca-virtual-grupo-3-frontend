# Copia este archivo a .env y reemplaza los valores necesarios.
VITE_API_URL=https://biblioteca-virtual-grupo-3.onrender.com

# Si quieres usar tu propia API de libros:
VITE_BOOK_API_URL=https://tu-api-de-libros.com/api/books

# Si quieres usar Google Books API, deja VITE_BOOK_API_URL vacío y configura la consulta:
VITE_GOOGLE_BOOKS_QUERY=
# Si tienes API key de Google Books, añádela aquí (opcional):
VITE_GOOGLE_BOOKS_API_KEY=
